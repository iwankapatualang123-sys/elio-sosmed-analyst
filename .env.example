# ── Environment variables elio-sosmed-analyst ──────────────────────────────
# Salin ke .env.local (dev) atau set di panel/PM2 (produksi). JANGAN commit .env asli.
#
# PENTING: NEXT_PUBLIC_* di-"bake" ke bundle browser SAAT `npm run build`.
# Jadi set nilai produksi SEBELUM build di server — bukan sesudahnya.

# URL API Supabase.
#  - Supabase Cloud : https://<project-ref>.supabase.co
#  - Self-host      : https://db.domain-anda.com  (domain reverse-proxy ke Supabase)
NEXT_PUBLIC_SUPABASE_URL=

# Kunci publik (anon) Supabase — aman tampil di browser (RLS yang menjaga data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Kunci service-role Supabase — RAHASIA, hanya dipakai server (admin actions,
# reset password, backup). Jangan pernah bocor ke browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Insight (opsional) ───────────────────────────────────────────────────
# Kosongkan kalau tidak pakai fitur Insight AI (Groq). Aplikasi tetap jalan.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
