# ── Environment variables elio-sosmed-analyst (aaPanel / MySQL) ─────────────
# Salin ke .env.local (dev) atau set di panel/PM2 (produksi). JANGAN commit .env asli.

# ── Database (MySQL self-host aaPanel) ──────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql://elio_sosmed:PASSWORD@127.0.0.1:3306/elio_sosmed

# ── Auth (JWT sesi login) ───────────────────────────────────────────────────
# Rahasia penanda-tangan cookie sesi. Minimal 32 karakter acak.
# Generate: node scripts/gen-secret.mjs
# PENTING: jangan diubah setelah dipakai — mengubahnya membatalkan semua sesi login.
AUTH_JWT_SECRET=

# ── Migrasi data dari Supabase lama (hanya saat cutover, boleh dihapus setelah) ─
# SRC_SUPABASE_URL=https://<ref>.supabase.co
# SRC_SUPABASE_SERVICE_KEY=<service_role key Supabase lama>

# ── AI Insight (opsional) ───────────────────────────────────────────────────
# Kosongkan kalau tidak pakai fitur Insight AI (Groq). Aplikasi tetap jalan.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
